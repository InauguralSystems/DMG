# ============================================================
# DMG CPU unit tests
# ============================================================

load_file of "src/cpu.eigs"
load_file of "src/memory.eigs"
load_file of "src/lcd.eigs"
load_file of "src/opcodes.eigs"

# This unit test loads the cpu/memory/opcodes subsystem but NOT dmg.eigs (whose
# main loop runs at top level). Two pieces of emulator glue that live in
# dmg.eigs must be provisioned here so the opcode memory paths resolve:
#   - bus_flush: cpu_mem_read/write call it on MMIO access. Mirrors
#     dmg.eigs:bus_flush exactly (self-contained — folds the deferred
#     pending_cycles into stepped_cycles).
#   - init_exec_ctx: called per cpu/mem below. exec_op reads cpu/mem from the
#     module-global _exec_ctx, which the emulator wires once at startup
#     (dmg.eigs) and exec_op intentionally does not re-wire per call.
define bus_flush(cpu, mem) as:
    cycles is mem.pending_cycles
    if cycles <= 0:
        return null
    mem.pending_cycles is 0
    cpu.stepped_cycles += cycles

print of "=== DMG CPU tests ==="

# Helper: load bytes into memory at addr
define load_bytes(mem, addr, bytes) as:
    for i in range of (len of bytes):
        mem.data[addr + i] is bytes[i]

# ---- Register pair tests ----
cpu is new_cpu of null
set_bc of [cpu, 0x1234]
assert of [get_bc of cpu == 0x1234, "BC = 0x1234"]
assert of [cpu.b == 0x12, "B = 0x12"]
assert of [cpu.c == 0x34, "C = 0x34"]
set_hl of [cpu, 0xABCD]
assert of [get_hl of cpu == 0xABCD, "HL = 0xABCD"]
print of "  register pairs: ok"

# ---- Flag tests ----
set_flags of [cpu, 1, 0, 1, 0]
assert of [cpu.f == 0xA0, f"flags ZH = 0xA0, got 0x{cpu.f}"]
assert of [(flag_z of cpu) == 1, "Z set"]
assert of [(flag_h of cpu) == 1, "H set"]
assert of [(flag_c of cpu) == 0, "C clear"]
print of "  flags: ok"

# ---- ALU ADD ----
cpu is new_cpu of null
cpu.a is 0x3A
alu_add of [cpu, 0xC6]
assert of [cpu.a == 0x00, f"0x3A + 0xC6 = 0x00, got 0x{cpu.a}"]
assert of [(flag_z of cpu) == 1, "Z set on zero"]
assert of [(flag_h of cpu) == 1, "H set"]
assert of [(flag_c of cpu) == 1, "C set on overflow"]
print of "  ALU ADD: ok"

# ---- ALU SUB ----
cpu is new_cpu of null
cpu.a is 0x3E
alu_sub of [cpu, 0x3E]
assert of [cpu.a == 0x00, "SUB self = 0"]
assert of [(flag_z of cpu) == 1, "Z set"]
assert of [(flag_n of cpu) == 1, "N set"]
print of "  ALU SUB: ok"

# ---- ALU AND/XOR/OR ----
cpu is new_cpu of null
cpu.a is 0x5A
alu_and of [cpu, 0x3F]
assert of [cpu.a == 0x1A, f"AND 0x5A & 0x3F = 0x1A, got 0x{cpu.a}"]
cpu.a is 0xFF
alu_xor of [cpu, 0xFF]
assert of [cpu.a == 0x00, "XOR self = 0"]
assert of [(flag_z of cpu) == 1, "XOR Z set"]
print of "  ALU AND/XOR/OR: ok"

# ---- INC/DEC ----
cpu is new_cpu of null
cpu.a is 0xFF
cpu.a is alu_inc of [cpu, cpu.a]
assert of [cpu.a == 0x00, "INC 0xFF = 0x00"]
assert of [(flag_z of cpu) == 1, "INC Z set"]
assert of [(flag_h of cpu) == 1, "INC H set"]
cpu.a is alu_dec of [cpu, cpu.a]
assert of [cpu.a == 0xFF, "DEC 0x00 = 0xFF"]
print of "  INC/DEC: ok"

# ---- Opcode execution: NOP ----
cpu is new_cpu of null
mem is new_memory of null
init_exec_ctx of [cpu, mem]
cpu.pc is 0x0100
load_bytes of [mem, 0x0100, [0x00]]
cycles is exec_op of [cpu, mem]
assert of [cycles == 4, "NOP = 4 cycles"]
assert of [cpu.pc == 0x0101, "PC advanced"]
print of "  NOP: ok"

# ---- Opcode: LD B, 0x42 (0x06 0x42) ----
cpu is new_cpu of null
mem is new_memory of null
init_exec_ctx of [cpu, mem]
cpu.pc is 0x0100
load_bytes of [mem, 0x0100, [0x06, 0x42]]
cycles is exec_op of [cpu, mem]
assert of [cpu.b == 0x42, f"LD B, 0x42: got 0x{cpu.b}"]
assert of [cycles == 8, "LD r, d8 = 8 cycles"]
print of "  LD B, d8: ok"

# ---- Opcode: XOR A (0xAF) — clears A, sets Z ----
cpu is new_cpu of null
mem is new_memory of null
init_exec_ctx of [cpu, mem]
cpu.pc is 0x0100
cpu.a is 0x42
load_bytes of [mem, 0x0100, [0xAF]]
exec_op of [cpu, mem]
assert of [cpu.a == 0x00, "XOR A clears A"]
assert of [(flag_z of cpu) == 1, "XOR A sets Z"]
print of "  XOR A: ok"

# ---- Opcode: JP a16 (0xC3) ----
cpu is new_cpu of null
mem is new_memory of null
init_exec_ctx of [cpu, mem]
cpu.pc is 0x0100
load_bytes of [mem, 0x0100, [0xC3, 0x50, 0x01]]
cycles is exec_op of [cpu, mem]
assert of [cpu.pc == 0x0150, f"JP 0x0150: PC=0x{cpu.pc}"]
assert of [cycles == 16, "JP = 16 cycles"]
print of "  JP a16: ok"

# ---- Opcode: CALL/RET ----
cpu is new_cpu of null
mem is new_memory of null
init_exec_ctx of [cpu, mem]
cpu.pc is 0x0100
cpu.sp is 0xFFFE
load_bytes of [mem, 0x0100, [0xCD, 0x50, 0x01]]
load_bytes of [mem, 0x0150, [0xC9]]
exec_op of [cpu, mem]
assert of [cpu.pc == 0x0150, "CALL jumped to 0x0150"]
assert of [cpu.sp == 0xFFFC, "SP decremented by 2"]
exec_op of [cpu, mem]
assert of [cpu.pc == 0x0103, f"RET returned to 0x0103, got 0x{cpu.pc}"]
assert of [cpu.sp == 0xFFFE, "SP restored"]
print of "  CALL/RET: ok"

# ---- Opcode: PUSH/POP BC ----
cpu is new_cpu of null
mem is new_memory of null
init_exec_ctx of [cpu, mem]
cpu.sp is 0xFFFE
set_bc of [cpu, 0x1234]
cpu.pc is 0x0100
load_bytes of [mem, 0x0100, [0xC5, 0xC1]]
exec_op of [cpu, mem]
assert of [cpu.sp == 0xFFFC, "PUSH SP-=2"]
set_bc of [cpu, 0x0000]
exec_op of [cpu, mem]
assert of [get_bc of cpu == 0x1234, f"POP BC = 0x1234, got 0x{get_bc of cpu}"]
print of "  PUSH/POP: ok"

# ---- CB prefix: SWAP A ----
cpu is new_cpu of null
mem is new_memory of null
init_exec_ctx of [cpu, mem]
cpu.pc is 0x0100
cpu.a is 0xF1
load_bytes of [mem, 0x0100, [0xCB, 0x37]]
exec_op of [cpu, mem]
assert of [cpu.a == 0x1F, f"SWAP 0xF1 = 0x1F, got 0x{cpu.a}"]
print of "  CB SWAP: ok"

# ---- CB prefix: BIT 7, A ----
cpu is new_cpu of null
mem is new_memory of null
init_exec_ctx of [cpu, mem]
cpu.pc is 0x0100
cpu.a is 0x80
load_bytes of [mem, 0x0100, [0xCB, 0x7F]]
exec_op of [cpu, mem]
assert of [(flag_z of cpu) == 0, "BIT 7 of 0x80 = not zero"]
cpu.pc is 0x0100
cpu.a is 0x7F
exec_op of [cpu, mem]
assert of [(flag_z of cpu) == 1, "BIT 7 of 0x7F = zero"]
print of "  CB BIT: ok"

# ---- STOP / CGB speed switch ----
cpu is new_cpu of null
mem is new_memory of null
init_exec_ctx of [cpu, mem]
cpu.pc is 0x0100
mem.data[0xFF04] is 0xAB
mem.div_counter is 100
load_bytes of [mem, 0x0100, [0x10, 0x00]]
exec_op of [cpu, mem]
assert of [cpu.stopped == 1, "STOP without KEY1 arms stopped state"]
assert of [cpu.pc == 0x0102, "STOP consumes padding byte"]
assert of [mem.data[0xFF04] == 0, "STOP resets DIV (#32)"]
assert of [mem.div_counter == 0, "STOP resets DIV internal divider (#32)"]

cpu is new_cpu of null
mem is new_memory of null
init_exec_ctx of [cpu, mem]
cpu.pc is 0x0100
mem.data[0xFF4D] is 0x01
load_bytes of [mem, 0x0100, [0x10, 0x00]]
exec_op of [cpu, mem]
assert of [cpu.stopped == 0, "STOP with KEY1 speed request continues"]
assert of [mem.data[0xFF4D] == 0x80, "STOP toggles KEY1 speed bit on"]
print of "  STOP/KEY1: ok"

# ---- fetch8 honors the MBC1 mode-1 bank0 remap (#27) ----
# On a >=512KB MBC1 cart in banking mode 1, reads below 0x4000 come from
# bank (bank2 << 5). fetch8 must see the same bytes as cpu_mem_read/mem_read
# — it silently fetched bank 0 while data reads were remapped.
cpu is new_cpu of null
mem is new_memory of null
banks is 64
rom is buffer of (banks * 0x4000)
for bank in range of banks:
    rom[(bank * 0x4000) + 0x1234] is (bank + 0x31) & 0xFF
mem.rom is rom
mem.rom_len is banks * 0x4000
mem.mbc_type is 1
mem_write of [mem, 0x6000, 0x01]
mem_write of [mem, 0x4000, 0x01]
assert of [mem_read of [mem, 0x1234] == ((0x20 + 0x31) & 0xFF), "mem_read remaps mode-1 bank0"]
cpu.pc is 0x1234
fetched is fetch8 of [cpu, mem]
assert of [fetched == ((0x20 + 0x31) & 0xFF), f"fetch8 remaps mode-1 bank0: expected 0x51, got {fetched}"]
assert of [cpu.pc == 0x1235, "fetch8 advanced PC"]
# Mode 0: bank0 window reads straight-through again
mem_write of [mem, 0x6000, 0x00]
cpu.pc is 0x1234
assert of [(fetch8 of [cpu, mem]) == 0, "fetch8 mode 0 reads unbanked bank 0"]
print of "  fetch8 MBC1 mode-1 bank0 remap: ok"

print of "\n=== All CPU tests passed ==="
